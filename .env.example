# ChainSplit Environment Configuration
# Copy this file to .env and fill in your values

#=============================================================================
# DEPLOYMENT KEYS (NEVER COMMIT REAL KEYS!)
#=============================================================================

# Deployer private key (without 0x prefix)
PRIVATE_KEY=

# Etherscan API key for contract verification
ETHERSCAN_API_KEY=
POLYGONSCAN_API_KEY=
BASESCAN_API_KEY=

#=============================================================================
# RPC ENDPOINTS
#=============================================================================

# Infura/Alchemy API key
INFURA_KEY=
ALCHEMY_KEY=

# Or direct RPC URLs
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/${INFURA_KEY}
POLYGON_RPC_URL=https://polygon-mainnet.infura.io/v3/${INFURA_KEY}
MUMBAI_RPC_URL=https://polygon-mumbai.infura.io/v3/${INFURA_KEY}
BASE_RPC_URL=https://mainnet.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

#=============================================================================
# DEPLOYED CONTRACT ADDRESSES
#=============================================================================

# Factory address (set after deployment)
FACTORY_ADDRESS=

# Token addresses (for testing)
# Sepolia USDC: 0x1c7D4B196Cb0C7B01d743Fbc6116a902379C7238
TOKEN_ADDRESS=

#=============================================================================
# GROUP CREATION
#=============================================================================

# Group parameters
GROUP_NAME=My Trip
DEPOSIT_AMOUNT=100000000
DEADLINE_DAYS=2

# Members (up to 5 supported)
MEMBER_1=
MEMBER_2=
MEMBER_3=
MEMBER_4=
MEMBER_5=

#=============================================================================
# INTERACTION PARAMETERS
#=============================================================================

# Group address for interactions
GROUP_ADDRESS=

# Expense parameters
EXPENSE_AMOUNT=
EXPENSE_ID=
IPFS_CID=
